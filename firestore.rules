rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function myRole(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role;
    }

    function isFamilyAdmin(familyId) {
      return isFamilyMember(familyId) && (myRole(familyId) in ['owner', 'admin']);
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if signedIn();
      allow update: if isFamilyAdmin(familyId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow create: if signedIn();
        allow update: if isFamilyAdmin(familyId) || request.auth.uid == memberId;
        allow delete: if isFamilyAdmin(familyId);
      }

      match /items/{docId} {
        allow read, create, update, delete: if isFamilyMember(familyId);
      }

      match /shopping/{docId} {
        allow read, create, update, delete: if isFamilyMember(familyId);
      }

      match /tasks/{docId} {
        allow read, create, update, delete: if isFamilyMember(familyId);
      }

      match /bills/{docId} {
        allow read, create, update, delete: if isFamilyMember(familyId);
      }

      match /expenses/{docId} {
        allow read, create, update, delete: if isFamilyMember(familyId);
      }
    }
  }
}
